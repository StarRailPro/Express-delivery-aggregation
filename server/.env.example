# 服务端口
PORT=3000

# MongoDB 连接地址
MONGODB_URI=mongodb://localhost:27017/express-delivery

# JWT 密钥（生产环境请使用强随机字符串）
JWT_SECRET=your_jwt_secret_key_here

# JWT Token 有效期（默认 7 天）
JWT_EXPIRES_IN=7d

# 快递 API 配置（快递鸟 / 快递100）
EXPRESS_API_PROVIDER=kdniao
EXPRESS_API_KEY=your_express_api_key_here
EXPRESS_API_SECRET=your_express_api_secret_here

# 高德地图 API 配置
AMAP_SERVER_KEY=your_amap_server_key_here
AMAP_JS_KEY=your_amap_js_key_here

# CORS 允许的源（生产环境请限制）
CORS_ORIGIN=http://localhost:5173

# 定时刷新调度器配置
# cron 表达式，默认每2小时执行一次: "0 */2 * * *"
# 测试时可改为每10秒: "*/10 * * * * *"
SCHEDULER_CRON_EXPRESSION=0 */2 * * *
